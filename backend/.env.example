# Server Configuration
PORT=4000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here
JWT_SECRET=your_jwt_secret_key_here

# MongoDB Configuration
# Use the full connection string including the database name.
# Example (Atlas SRV): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/e-commerce?retryWrites=true&w=majority
# If SRV DNS lookups fail in your environment, use the standard connection string:
# mongodb://<user>:<password>@host1:27017,host2:27017/<db>?replicaSet=<rs>&ssl=true&authSource=admin
MONGODB_URI=your_mongodb_connection_string_here
# Optional fallback URI when SRV lookup fails
MONGODB_URI_FALLBACK=your_standard_mongodb_connection_string_here

# Cloudinary Configuration
CLOUDINARY_NAME=your_cloudinary_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_SECRET_KEY=your_cloudinary_secret_key_here

# Payment Gateway Configuration
STRIPE_SECRET_KEY=your_stripe_secret_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Configuration
EMAIL_USER=your_email_here
EMAIL_APP_PASSWORD=your_email_app_password_here

# Frontend URLs for CORS (Production)
FRONTEND_URL=https://wellfire-frontend-oa5j.onrender.com
ADMIN_URL=https://wellfire-new2.onrender.com
